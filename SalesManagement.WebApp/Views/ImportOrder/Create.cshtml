@model SalesManagement.WebApp.Models.CreateImportOrderViewModel

@{
    ViewData["Title"] = "Lập Phiếu Nhập Kho";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Lập Phiếu Nhập Kho</h1>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            <div asp-validation-summary="All" class="text-danger"></div>
        </div>
    }

    <form asp-action="Create" method="post">
        <div class="card mb-4 mt-3">
            <div class="card-header bg-primary text-white">
                <i class="fas fa-file-invoice me-1"></i> Thông tin phiếu nhập
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="SupplierId" class="control-label fw-bold">Nhà cung cấp <span class="text-danger">*</span></label>
                            <select asp-for="SupplierId" class="form-select" asp-items="ViewBag.Suppliers"
                                    onchange="window.location.href='/ImportOrder/Create?selectedSupplierId=' + this.value;">
                                <option value="">--- Chọn Nhà cung cấp ---</option>
                            </select>
                            <span asp-validation-for="SupplierId" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="Note" class="control-label fw-bold">Ghi chú</label>
                            <input asp-for="Note" class="form-control" placeholder="Nhập ghi chú (nếu có)..." />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                <span><i class="fas fa-box-open me-1"></i> Danh sách mặt hàng nhập</span>
                @if (ViewBag.Products != null)
                {
                    <button type="button" id="btnAddRow" class="btn btn-success btn-sm mt-2">
                        <i class="fas fa-plus"></i> Thêm mặt hàng
                    </button>
                }
                else
                {
                    <div class="alert alert-warning mt-2 p-2">
                        <i class="fas fa-info-circle"></i> Vui lòng chọn Nhà cung cấp ở trên để tải danh sách mặt hàng.
                    </div>
                }
            </div>
            <div class="card-body p-0">
                <table class="table table-bordered table-striped mb-0" id="detailsTable">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 40%">Sản phẩm</th>
                            <th style="width: 20%">Số lượng</th>
                            <th style="width: 30%">Giá vốn (VNĐ)</th>
                            <th style="width: 10%" class="text-center">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="form-group mb-5">
            <button type="submit" class="btn btn-primary btn-lg"><i class="fas fa-save"></i> Hoàn tất nhập kho</button>
            <a asp-action="Index" class="btn btn-secondary btn-lg"><i class="fas fa-times"></i> Hủy bỏ</a>
        </div>
    </form>
</div>

<table id="rowTemplate" style="display:none;">
    <tr>
        <td>
            <select class="form-select product-select" required>
                <option value="">-- Chọn Sản phẩm --</option>
                @if (ViewBag.Products != null)
                {
                    foreach (var item in ViewBag.Products as SelectList)
                    {
                        <option value="@item.Value">@item.Text</option>
                    }
                }
            </select>
        </td>
        <td>
            <input type="number" class="form-control quantity-input text-center" min="1" value="1" required />
        </td>
        <td>
            <input type="number" step="0.01" class="form-control cost-input text-end" min="0" required />
        </td>
        <td class="text-center">
            <button type="button" class="btn btn-danger btn-sm btn-remove-row"><i class="fas fa-trash"></i></button>
        </td>
    </tr>
</table>
@section Scripts {
    <script>
        $(document).ready(function () {

            // 1. Hàm thêm dòng mới từ Template
            function addRow() {
                // Copy ruột của dòng mẫu
                var newRow = $('#rowTemplate tbody tr').clone();
                // Dán vào bảng chính
                $('#detailsTable tbody').append(newRow);
                // Đánh lại số thứ tự index
                reindexTable();
            }

            // 2. Hàm đánh lại index để C# đọc được thành dạng List<ImportOrderDetail>
            function reindexTable() {
                $('#detailsTable tbody tr').each(function (index) {
                    $(this).find('.product-select').attr('name', 'Details[' + index + '].ProductId');
                    $(this).find('.quantity-input').attr('name', 'Details[' + index + '].Quantity');
                    $(this).find('.cost-input').attr('name', 'Details[' + index + '].UnitCost');
                });
            }

            // 3. Bấm nút Thêm mặt hàng thì gọi hàm addRow
            $('#btnAddRow').click(function () {
                addRow();
            });

            // 4. Xử lý sự kiện bấm nút Xóa (thùng rác)
            $(document).on('click', '.btn-remove-row', function () {
                var rowCount = $('#detailsTable tbody tr').length;
                if (rowCount > 1) {
                    $(this).closest('tr').remove();
                    reindexTable();
                } else {
                    alert('Phải có ít nhất 1 mặt hàng trong phiếu nhập!');
                }
            });

            // 5. QUAN TRỌNG: Tự động thêm 1 dòng đầu tiên nếu Server trả về danh sách sản phẩm
            @if (ViewBag.Products != null)
            {
                    <text>
                        addRow();
                    </text>
            }
        });
    </script>
}