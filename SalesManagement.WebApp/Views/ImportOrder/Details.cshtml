@model SalesManagement.Data.Entities.ImportOrder

@{
    ViewData["Title"] = "Chi tiết Phiếu Nhập";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Chi tiết Phiếu Nhập Kho</h1>

    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white fw-bold">
                    <i class="fas fa-info-circle"></i> Thông tin chung
                </div>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item"><strong>Mã phiếu:</strong> <span class="text-primary fw-bold">@Model.Code</span></li>
                    <li class="list-group-item"><strong>Ngày nhập:</strong> @Model.ImportDate.ToString("dd/MM/yyyy HH:mm")</li>
                    <li class="list-group-item">
                        <strong>Trạng thái:</strong>
                        @if (Model.Status == SalesManagement.Data.Entities.ImportOrderStatus.Completed)
                        {
                            <span class="badge bg-success">Đã hoàn tất</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@Model.Status</span>
                        }
                    </li>
                    <li class="list-group-item"><strong>Người lập phiếu:</strong> @(Model.CreatedByAccount?.FullName ?? "N/A")</li>
                    <li class="list-group-item"><strong>Ghi chú:</strong> @(string.IsNullOrEmpty(Model.Note) ? "Không có" : Model.Note)</li>
                </ul>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-info text-white fw-bold">
                    <i class="fas fa-truck"></i> Thông tin Nhà cung cấp
                </div>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item"><strong>Tên đối tác:</strong> @(Model.Supplier?.CompanyName ?? "N/A")</li>
                    <li class="list-group-item"><strong>Số điện thoại:</strong> @(Model.Supplier?.ContactPhone ?? "N/A")</li>
                    <li class="list-group-item"><strong>Email:</strong> @(Model.Supplier?.Email ?? "N/A")</li>
                </ul>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-success text-white fw-bold">
                    <i class="fas fa-box-open"></i> Chi tiết mặt hàng
                </div>
                <div class="card-body p-0">
                    <table class="table table-striped table-bordered mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>STT</th>
                                <th>Sản phẩm</th>
                                <th class="text-center">Số lượng</th>
                                <th class="text-end">Đơn giá nhập</th>
                                <th class="text-end">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int stt = 1;
                            }
                            @foreach (var item in Model.ImportOrderDetails)
                            {
                                <tr>
                                    <td class="text-center">@(stt++)</td>
                                    <td>@(item.Product?.Name ?? "Sản phẩm không xác định")</td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="text-end">@item.UnitCost.ToString("N0") VNĐ</td>
                                    <td class="text-end fw-bold">@((item.Quantity * item.UnitCost).ToString("N0")) VNĐ</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-warning">
                                <td colspan="4" class="text-end fw-bold text-danger">TỔNG CỘNG:</td>
                                <td class="text-end fw-bold text-danger fs-5">@Model.TotalCost.ToString("N0") VNĐ</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
            <div class="text-end">
                <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại danh sách</a>
                <button class="btn btn-primary" onclick="window.print()"><i class="fas fa-print"></i> In phiếu</button>
            </div>
        </div>
    </div>
</div>