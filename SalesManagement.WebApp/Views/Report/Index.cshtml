@model IEnumerable<SalesManagement.Data.Entities.Product>

@{
    ViewData["Title"] = "Báo cáo hàng sắp hết";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4">
    <h1 class="mt-4 text-danger"><i class="fas fa-exclamation-triangle"></i> Cảnh báo sắp hết hàng</h1>
    <p class="text-muted">Danh sách các mặt hàng có số lượng tồn kho từ 10 trở xuống cần nhập thêm.</p>

    <div class="card mb-4 border-danger">
        <div class="card-header bg-danger text-white">
            <i class="fas fa-table me-1"></i> Bảng kê chi tiết mặt hàng Low Stock
        </div>
        <div class="card-body">
            <table class="table table-bordered table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Mã Sản Phẩm</th>
                        <th>Tên Mặt Hàng</th>
                        <th>Đơn Giá Bán</th>
                        <th class="text-center">Tồn Kho Hiện Tại</th>
                        <th class="text-center">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td><span class="fw-bold">@item.Code</span></td>
                                <td>@item.Name</td>
                                <td>@item.Price.ToString("N0") VNĐ</td>
                                <td class="text-center">
                                    @if (item.Quantity == 0)
                                    {
                                        <span class="badge bg-dark fs-6">Hết sạch (0)</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger fs-6">@item.Quantity</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a asp-controller="ImportOrder" asp-action="Create" class="btn btn-sm btn-outline-danger">
                                        <i class="fas fa-plus-circle"></i> Lập phiếu nhập
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center fw-bold text-success">
                                <i class="fas fa-check-circle"></i> Không có mặt hàng nào cần nhập thêm!
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>