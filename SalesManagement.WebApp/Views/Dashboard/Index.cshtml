@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var isAdmin = User.IsInRole("Admin");
    var isSales = User.IsInRole("Sales") || isAdmin;
    var isProduct = User.IsInRole("ProductManager") || isAdmin;
    var isWarehouse = User.IsInRole("Warehouse") || isAdmin;
}

<div class="container-fluid pt-4 px-4">
    <div class="row g-4 mb-4">
        <div class="col-12">
            <h4 class="mb-0 text-primary"><i class="fa fa-tachometer-alt me-2"></i>Hệ thống Quản lý Bán hàng</h4>
            <p class="text-muted">Chào mừng bạn quay trở lại, @User.Identity?.Name!</p>
        </div>
    </div>

    @* ========================================== *@
    @* 1. KHU VỰC BÁN HÀNG (SALES)                *@
    @* ========================================== *@
    @if (isSales)
    {
        <div class="mb-5">
            <h5 class="mb-3"><i class="fa fa-shopping-cart text-primary me-2"></i>Khu vực Bán hàng</h5>
            <div class="row g-4">
                <div class="col-sm-6 col-xl-3">
                    <div class="bg-light rounded d-flex align-items-center justify-content-between p-4">
                        <i class="fa fa-chart-line fa-3x text-primary"></i>
                        <div class="ms-3">
                            <p class="mb-2">Doanh thu hôm nay</p>
                            <h6 class="mb-0">@String.Format("{0:N0}", ViewBag.TodayRevenue) ₫</h6>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-xl-3">
                    <div class="bg-light rounded d-flex align-items-center justify-content-between p-4">
                        <i class="fa fa-chart-bar fa-3x text-primary"></i>
                        <div class="ms-3">
                            <p class="mb-2">Tổng doanh thu</p>
                            <h6 class="mb-0">@String.Format("{0:N0}", ViewBag.TotalRevenue) ₫</h6>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-xl-3">
                    <div class="bg-light rounded d-flex align-items-center justify-content-between p-4">
                        <i class="fa fa-receipt fa-3x text-primary"></i>
                        <div class="ms-3">
                            <p class="mb-2">Đơn hàng hôm nay</p>
                            <h6 class="mb-0">@ViewBag.TodayOrders đơn</h6>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-xl-3">
                    <div class="bg-light rounded d-flex align-items-center justify-content-between p-4">
                        <i class="fa fa-users fa-3x text-primary"></i>
                        <div class="ms-3">
                            <p class="mb-2">Tổng khách hàng</p>
                            <h6 class="mb-0">@ViewBag.TotalCustomers người</h6>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-4 mt-2">
                <div class="col-12">
                    <div class="bg-light text-center rounded p-4">
                        <div class="d-flex align-items-center justify-content-between mb-4">
                            <h6 class="mb-0"><i class="fa fa-history me-2"></i>Đơn hàng gần đây</h6>
                            <a href="@Url.Action("Index", "Order")">Xem tất cả</a>
                        </div>
                        <div class="table-responsive">
                            <table class="table text-start align-middle table-bordered table-hover mb-0">
                                <thead>
                                    <tr class="text-dark">
                                        <th scope="col">Mã đơn</th>
                                        <th scope="col">Ngày tạo</th>
                                        <th scope="col">Tổng tiền</th>
                                        <th scope="col">Trạng thái</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (ViewBag.RecentOrders != null)
                                    {
                                        foreach (var order in ViewBag.RecentOrders)
                                        {
                                            <tr>
                                                <td>@order.Code</td>
                                                <td>@order.CreatedDate.ToString("dd/MM/yyyy HH:mm")</td>
                                                <td>@String.Format("{0:N0}", order.TotalAmount) ₫</td>
                                                <td>
                                                    @switch ((int)order.Status)
                                                    {
                                                        case 0: <span class="badge bg-warning">Chờ xử lý</span> break;
                                                        case 1: <span class="badge bg-success">Hoàn thành</span> break;
                                                        case 2: <span class="badge bg-danger">Đã hủy</span> break;
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    @* ========================================== *@
    @* 2. KHU VỰC SẢN PHẨM (PRODUCT)              *@
    @* ========================================== *@
    @if (isProduct)
    {
        <div class="mb-5">
            <h5 class="mb-3"><i class="fa fa-box text-success me-2"></i>Khu vực Sản phẩm</h5>
            <div class="row g-4">
                <div class="col-sm-6 col-xl-3">
                    <div class="bg-light rounded d-flex align-items-center justify-content-between p-4">
                        <i class="fa fa-boxes fa-3x text-success"></i>
                        <div class="ms-3">
                            <p class="mb-2">Tổng sản phẩm</p>
                            <h6 class="mb-0">@ViewBag.TotalProducts</h6>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-xl-3">
                    <div class="bg-light rounded d-flex align-items-center justify-content-between p-4">
                        <i class="fa fa-tags fa-3x text-success"></i>
                        <div class="ms-3">
                            <p class="mb-2">Tổng danh mục</p>
                            <h6 class="mb-0">@ViewBag.TotalCategories</h6>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-4 mt-2">
                <div class="col-12">
                    <div class="bg-light text-center rounded p-4">
                        <div class="d-flex align-items-center justify-content-between mb-4">
                            <h6 class="mb-0"><i class="fa fa-exclamation-triangle text-warning me-2"></i>Sản phẩm sắp hết hàng</h6>
                            <a href="@Url.Action("Index", "Product")">Xem tất cả</a>
                        </div>
                        <div class="table-responsive">
                            <table class="table text-start align-middle table-bordered table-hover mb-0">
                                <thead>
                                    <tr class="text-dark">
                                        <th scope="col">Mã SP</th>
                                        <th scope="col">Tên sản phẩm</th>
                                        <th scope="col">Tồn kho</th>
                                        <th scope="col">Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (ViewBag.LowStockProducts != null)
                                    {
                                        foreach (var product in ViewBag.LowStockProducts)
                                        {
                                            <tr>
                                                <td>@product.Code</td>
                                                <td>@product.Name</td>
                                                <td>
                                                    <span class="badge @(product.Quantity == 0 ? "bg-danger" : "bg-warning text-dark")">@product.Quantity</span>
                                                </td>
                                                <td>
                                                    <a href="@Url.Action("Create", "ImportOrder")" class="btn btn-sm btn-outline-primary">Nhập hàng</a>
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    @* ========================================== *@
    @* 3. KHU VỰC KHO HÀNG (WAREHOUSE)            *@
    @* ========================================== *@
    @if (isWarehouse)
    {
        <div class="mb-5">
            <h5 class="mb-3"><i class="fa fa-warehouse text-warning me-2"></i>Khu vực Kho hàng</h5>
            <div class="row g-4">
                <div class="col-sm-6 col-xl-3">
                    <div class="bg-light rounded d-flex align-items-center justify-content-between p-4">
                        <i class="fa fa-truck fa-3x text-warning"></i>
                        <div class="ms-3">
                            <p class="mb-2">Nhà cung cấp</p>
                            <h6 class="mb-0">@ViewBag.TotalSuppliers</h6>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-xl-3">
                    <div class="bg-light rounded d-flex align-items-center justify-content-between p-4">
                        <i class="fa fa-file-import fa-3x text-warning"></i>
                        <div class="ms-3">
                            <p class="mb-2">Đơn nhập hôm nay</p>
                            <h6 class="mb-0">@ViewBag.TodayImports</h6>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-xl-4">
                    <div class="bg-light rounded d-flex align-items-center justify-content-between p-4">
                        <i class="fa fa-money-bill-wave fa-3x text-warning"></i>
                        <div class="ms-3">
                            <p class="mb-2">Tổng chi nhập hàng</p>
                            <h6 class="mb-0">@String.Format("{0:N0}", ViewBag.TotalImportsAmount) ₫</h6>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-4 mt-2">
                <div class="col-12">
                    <div class="bg-light text-center rounded p-4">
                        <div class="d-flex align-items-center justify-content-between mb-4">
                            <h6 class="mb-0"><i class="fa fa-list me-2"></i>Đơn nhập kho gần đây</h6>
                            <a href="@Url.Action("Index", "ImportOrder")">Xem tất cả</a>
                        </div>
                        <div class="table-responsive">
                            <table class="table text-start align-middle table-bordered table-hover mb-0">
                                <thead>
                                    <tr class="text-dark">
                                        <th scope="col">Mã đơn nhập</th>
                                        <th scope="col">Ngày tạo</th>
                                        <th scope="col">Tổng tiền</th>
                                        <th scope="col">NCC</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (ViewBag.RecentImports != null)
                                    {
                                        foreach (var import in ViewBag.RecentImports)
                                        {
                                            <tr>
                                                <td>@import.Code</td>
                                                <td>@import.ImportDate.ToString("dd/MM/yyyy HH:mm")</td>
                                                <td>@String.Format("{0:N0}", import.TotalCost) ₫</td>
                                                <td>@import.Supplier?.CompanyName</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="row g-4 mt-4">
        <div class="col-12 text-center">
            <p class="text-muted small">© @DateTime.Now.Year - Hệ thống Quản lý Bán hàng PRN222</p>
        </div>
    </div>
</div>
