@model IEnumerable<SalesManagement.Data.Entities.Customer>

@{
    ViewData["Title"] = "Quản lý Khách hàng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var isSales = User.IsInRole("Sales");
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Danh sách Khách hàng</h1>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card mb-4 mt-3">
        <div class="card-header">
            @if (isSales)
            {
                <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus"></i> Thêm mới</a>
            }
            else
            {
                <span><i class="fas fa-users me-1"></i> Danh sách khách hàng đang hoạt động</span>
            }
        </div>
        <div class="card-body">
            <table class="table table-bordered table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Họ và tên</th>
                        <th>Số điện thoại</th>
                        <th>Email</th>
                        <th>Địa chỉ</th>
                        <th>Ngày tạo</th>
                        <th>Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.FullName</td>
                                <td>@item.Phone</td>
                                <td>@(string.IsNullOrWhiteSpace(item.Email) ? "Chưa cập nhật" : item.Email)</td>
                                <td>@(string.IsNullOrWhiteSpace(item.Address) ? "Chưa cập nhật" : item.Address)</td>
                                <td>@item.CreatedDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <a asp-action="History" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Lịch sử</a>
                                    @if (isSales)
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Sửa</a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" onclick="return confirm('Bạn có chắc muốn ngừng hoạt động khách hàng này?');">Xóa</a>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center">Chưa có dữ liệu khách hàng nào.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
