@* Sidebar Menu - Điều hướng chính *@
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    
    // Lấy thông tin user từ session hoặc claims
    var userName = User.Identity?.Name ?? "Guest";
    var isAdmin = User.IsInRole("Admin");
    var isSales = User.IsInRole("Sales") || isAdmin;
    var isProduct = User.IsInRole("ProductManager") || isAdmin;
    var isWarehouse = User.IsInRole("Warehouse") || isAdmin;

    // Xác định vai trò để hiển thị nhãn
    string userRoleLabel = "Guest";
    if (isAdmin) userRoleLabel = "Admin";
    else if (User.IsInRole("Sales")) userRoleLabel = "Sales";
    else if (User.IsInRole("ProductManager")) userRoleLabel = "Product Manager";
    else if (User.IsInRole("Warehouse")) userRoleLabel = "Warehouse";
}

<div class="sidebar pe-4 pb-3">
    <nav class="navbar bg-light navbar-light">
        <a href="@Url.Action("Index", "Dashboard")" class="navbar-brand mx-4 mb-3">
            <h3 class="text-primary"><i class="fa fa-store me-2"></i>Sales MS</h3>
        </a>
        <div class="d-flex align-items-center ms-4 mb-4">
            <div class="position-relative">
                <img class="rounded-circle" src="~/dashmin/img/user.jpg" alt="" style="width: 40px; height: 40px;">
                <div class="bg-success rounded-circle border border-2 border-white position-absolute end-0 bottom-0 p-1"></div>
            </div>
            <div class="ms-3">
                <h6 class="mb-0">@userName</h6>
                <span>@userRoleLabel</span>
            </div>
        </div>
        <div class="navbar-nav w-100">
            @* Dashboard *@
            <a href="@Url.Action("Index", "Dashboard")"
               class="nav-item nav-link @(currentController == "Dashboard" ? "active" : "")">
                <i class="fa fa-tachometer-alt me-2"></i>Dashboard
            </a>

            @* 1. Nhóm Quản lý Sản phẩm (Product + Admin) *@
            @if (isProduct)
            {
                <div class="nav-item dropdown">
                    <a href="#" class="nav-link dropdown-toggle @(currentController == "Product" || currentController == "Category" ? "active" : "")"
                       data-bs-toggle="dropdown">
                        <i class="fa fa-box me-2"></i>Sản phẩm
                    </a>
                    <div class="dropdown-menu bg-transparent border-0">
                        <a href="@Url.Action("Index", "Category")" class="dropdown-item">Danh mục</a>
                        <a href="@Url.Action("Index", "Product")" class="dropdown-item">Sản phẩm</a>
                    </div>
                </div>
            }

            @* 2. Nhóm Quản lý Bán hàng (Sales + Admin) *@
            @if (isSales)
            {
                <a href="@Url.Action("Index", "Order")"
                   class="nav-item nav-link @(currentController == "Order" ? "active" : "")">
                    <i class="fa fa-shopping-cart me-2"></i>Đơn hàng
                </a>

                <a href="@Url.Action("Index", "Customer")"
                   class="nav-item nav-link @(currentController == "Customer" ? "active" : "")">
                    <i class="fa fa-users me-2"></i>Khách hàng
                </a>
            }

            @* 3. Nhóm Quản lý Kho (Warehouse + Admin) *@
            @if (isWarehouse)
            {
                <div class="nav-item dropdown">
                    <a href="#" class="nav-link dropdown-toggle @(currentController == "Supplier" || currentController == "ImportOrder" || currentController == "Report" ? "active" : "")"
                       data-bs-toggle="dropdown">
                        <i class="fa fa-warehouse me-2"></i>Kho hàng
                    </a>
                    <div class="dropdown-menu bg-transparent border-0">
                        <a href="@Url.Action("Index", "Supplier")" class="dropdown-item">Nhà cung cấp</a>
                        <a href="@Url.Action("Index", "ImportOrder")" class="dropdown-item">Nhập kho</a>
                        <a href="@Url.Action("Index", "Report")" class="dropdown-item">Báo cáo kho</a>
                    </div>
                </div>
            }

            @* 4. Nhóm Quản trị (Admin only) *@
            @if (isAdmin)
            {
                <hr class="my-2">
                <small class="nav-item text-muted px-3">QUẢN TRỊ HỆ THỐNG</small>

                <a href="@Url.Action("Index", "User")"
                   class="nav-item nav-link @(currentController == "User" || currentController == "Account" ? "active" : "")">
                    <i class="fa fa-user-cog me-2"></i>Tài khoản
                </a>
                
                <a href="@Url.Action("Index", "Role")"
                   class="nav-item nav-link @(currentController == "Role" ? "active" : "")">
                    <i class="fa fa-shield-alt me-2"></i>Phân quyền
                </a>
            }
        </div>
    </nav>
</div>
