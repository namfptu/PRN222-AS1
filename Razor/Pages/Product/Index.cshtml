@page
@namespace Razor.Pages.Products
@model Razor.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Quản lý Sản phẩm";
}

<div class="container-fluid pt-4 px-4">
    <div class="bg-light rounded p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h6 class="mb-0">Danh sách sản phẩm</h6>
            <a asp-page="/Product/Create" class="btn btn-primary">+ Thêm mới</a>
        </div>

        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Ảnh</th>
                        <th>Mã SP</th>
                        <th>Tên sản phẩm</th>
                        <th>Danh mục</th>
                        <th>Giá</th>
                        <th>Tồn kho</th>
                        <th>Trạng thái</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Products.Any())
                    {
                        foreach (var item in Model.Products)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" alt="@item.Name" style="width:50px;height:50px;object-fit:cover;" class="rounded" />
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>@item.Code</td>
                                <td>@item.Name</td>
                                <td>@item.Category?.Name</td>
                                <td>@String.Format("{0:N0}", item.Price) ₫</td>
                                <td>
                                    <span class="badge @(item.Quantity < 10 ? "bg-warning text-dark" : "bg-success")">@item.Quantity</span>
                                </td>
                                <td>
                                    @if (item.Status)
                                    {
                                        <span class="badge bg-success">Đang bán</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Ngừng bán</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a asp-page="/Product/Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-2">✏️</a>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" class="d-inline"
                                          onsubmit="return confirm('Bạn có chắc chắn muốn xóa/ngừng bán sản phẩm này?');">
                                        <button type="submit" class="btn btn-sm btn-danger">🗑️</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="8" class="text-center">Không có dữ liệu hiển thị.</td></tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between align-items-center mt-3">
            <div>Trang @Model.Products.PageIndex / @Model.Products.TotalPages</div>
            <nav>
                <ul class="pagination mb-0">
                    <li class="page-item @(!Model.Products.HasPreviousPage ? "disabled" : "")">
                        <a class="page-link" asp-page="/Product/Index" asp-route-pageNumber="@(Model.Products.PageIndex - 1)">Trước</a>
                    </li>
                    @for (int i = 1; i <= Model.Products.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Products.PageIndex ? "active" : "")">
                            <a class="page-link" asp-page="/Product/Index" asp-route-pageNumber="@i">@i</a>
                        </li>
                    }
                    <li class="page-item @(!Model.Products.HasNextPage ? "disabled" : "")">
                        <a class="page-link" asp-page="/Product/Index" asp-route-pageNumber="@(Model.Products.PageIndex + 1)">Sau</a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>
