@page
@namespace Razor.Pages.Suppliers
@model Razor.Pages.Suppliers.IndexModel
@{  ViewData["Title"] = "Quản lý Nhà cung cấp"; }
<div class="container-fluid pt-4 px-4">
    <div class="bg-light rounded p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h6 class="mb-0">Danh sách nhà cung cấp</h6>
            @if (User.IsInRole("Warehouse"))
            {
                <a asp-page="/Supplier/Create" class="btn btn-primary">+ Thêm mới</a>
            }
        </div>
        <div class="table-responsive">
            <table class="table table-hover">
                <thead><tr><th>Tên công ty</th><th>Email</th><th>SĐT</th><th>Địa chỉ</th><th>Trạng thái</th><th class="text-center">Thao tác</th></tr></thead>
                <tbody>
                    @foreach (var s in Model.Suppliers)
                    {
                        <tr>
                            <td>@s.CompanyName</td>
                            <td>@s.Email</td>
                            <td>@s.ContactPhone</td>
                            <td>@s.Address</td>
                            <td><span class="badge @(s.Status ? "bg-success" : "bg-secondary")">@(s.Status ? "Hoạt động" : "Ngừng")</span></td>
                            <td class="text-center">
                                @if (User.IsInRole("Warehouse"))
                                {
                                    <a asp-page="/Supplier/Edit" asp-route-id="@s.Id" class="btn btn-sm btn-warning me-1">✏️</a>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@s.Id" class="d-inline"
                                          onsubmit="return confirm('Ngừng hoạt động nhà cung cấp này?');">
                                        <button class="btn btn-sm btn-danger">🗑️</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
