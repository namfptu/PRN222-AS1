@page
@namespace Razor.Pages.Users
@model Razor.Pages.Users.IndexModel
@{  ViewData["Title"] = "Quản lý Người dùng"; }
<div class="container-fluid pt-4 px-4">
    <div class="bg-light rounded p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h6 class="mb-0">Danh sách người dùng hệ thống</h6>
            <a asp-page="/User/Create" class="btn btn-primary">+ Thêm người dùng</a>
        </div>
        <div class="table-responsive">
            <table class="table table-hover">
                <thead><tr><th>Họ tên</th><th>Email</th><th>Vai trò</th><th>Trạng thái</th><th class="text-center">Thao tác</th></tr></thead>
                <tbody>
                    @foreach (var u in Model.Users)
                    {
                        <tr>
                            <td>@u.FullName</td>
                            <td>@u.Email</td>
                            <td><span class="badge bg-info text-dark">@u.RoleName</span></td>
                            <td><span class="badge @(u.IsActive ? "bg-success" : "bg-danger")">@(u.IsActive ? "Hoạt động" : "Khóa")</span></td>
                            <td class="text-center">
                                <a asp-page="/User/Edit" asp-route-id="@u.Id" class="btn btn-sm btn-warning me-1">✏️</a>
                                <a asp-page="/User/ResetPassword" asp-route-id="@u.Id" class="btn btn-sm btn-secondary">🔑</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
