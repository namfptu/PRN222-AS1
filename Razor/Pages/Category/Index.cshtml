@page
@namespace Razor.Pages.Categories
@model Razor.Pages.Categories.IndexModel
@{
    ViewData["Title"] = "Quản lý Danh mục";
}

<div class="container-fluid pt-4 px-4">
    <div class="bg-light rounded p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h6 class="mb-0">Danh sách danh mục sản phẩm</h6>
            <a asp-page="/Category/Create" class="btn btn-primary">+ Thêm mới</a>
        </div>

        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Tên danh mục</th>
                        <th>Mô tả</th>
                        <th>Trạng thái</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Categories.Any())
                    {
                        foreach (var item in Model.Categories)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.Name</td>
                                <td>@item.Description</td>
                                <td>
                                    @if (item.Status)
                                    {
                                        <span class="badge bg-success">Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Khóa</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a asp-page="/Category/Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-2">✏️</a>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" class="d-inline"
                                          onsubmit="return confirm('Bạn có chắc chắn muốn xóa danh mục này?');">
                                        <button type="submit" class="btn btn-sm btn-danger">🗑️</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="5" class="text-center">Không có dữ liệu hiển thị.</td></tr>
                    }
                </tbody>
            </table>
        </div>

        @* Pagination *@
        <div class="d-flex justify-content-between align-items-center mt-3">
            <div>Trang @Model.Categories.PageIndex / @Model.Categories.TotalPages</div>
            <nav>
                <ul class="pagination mb-0">
                    <li class="page-item @(!Model.Categories.HasPreviousPage ? "disabled" : "")">
                        <a class="page-link" asp-page="/Category/Index" asp-route-pageNumber="@(Model.Categories.PageIndex - 1)">Trước</a>
                    </li>
                    @for (int i = 1; i <= Model.Categories.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Categories.PageIndex ? "active" : "")">
                            <a class="page-link" asp-page="/Category/Index" asp-route-pageNumber="@i">@i</a>
                        </li>
                    }
                    <li class="page-item @(!Model.Categories.HasNextPage ? "disabled" : "")">
                        <a class="page-link" asp-page="/Category/Index" asp-route-pageNumber="@(Model.Categories.PageIndex + 1)">Sau</a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>
