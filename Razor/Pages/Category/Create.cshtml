@page
@namespace Razor.Pages.Categories
@model Razor.Pages.Categories.CreateModel
@{
    ViewData["Title"] = "Thêm danh mục";
}

<div class="container-fluid pt-4 px-4">
    <div class="bg-light rounded p-4" style="max-width: 600px;">
        <h6 class="mb-4">Thêm danh mục mới</h6>
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Input.Name" class="form-label"></label>
                <input asp-for="Input.Name" class="form-control" placeholder="Nhập tên danh mục..." />
                <span asp-validation-for="Input.Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.Description" class="form-label"></label>
                <textarea asp-for="Input.Description" class="form-control" rows="3" placeholder="Nhập mô tả..."></textarea>
            </div>
            <div class="mb-3 form-check">
                <input asp-for="Input.Status" class="form-check-input" />
                <label asp-for="Input.Status" class="form-check-label">Hoạt động</label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">💾 Lưu</button>
                <a asp-page="/Category/Index" class="btn btn-secondary">Hủy</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
