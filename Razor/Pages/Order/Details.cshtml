@page "{id:int}"
@namespace Razor.Pages.Orders
@model Razor.Pages.Orders.DetailsModel
@{  ViewData["Title"] = "Chi tiết đơn hàng"; }
<div class="container-fluid pt-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5>Đơn hàng: <strong>@Model.Order!.Code</strong></h5>
        <a asp-page="/Order/Index" class="btn btn-secondary btn-sm">← Quay lại</a>
    </div>

    <div class="row">
        <div class="col-md-6">
            <dl class="row">
                <dt class="col-sm-5">Khách hàng</dt><dd class="col-sm-7">@Model.Order.CustomerName</dd>
                <dt class="col-sm-5">SĐT</dt><dd class="col-sm-7">@Model.Order.CustomerPhone</dd>
                <dt class="col-sm-5">Ngày tạo</dt><dd class="col-sm-7">@Model.Order.CreatedDate.ToString("dd/MM/yyyy HH:mm")</dd>
                <dt class="col-sm-5">Ghi chú</dt><dd class="col-sm-7">@Model.Order.Note</dd>
                <dt class="col-sm-5">Trạng thái</dt>
                <dd class="col-sm-7">
                    @switch (Model.Order.Status)
                    {
                        case SalesManagement.Data.Entities.OrderStatus.Pending: <span class="badge bg-warning">Chờ xử lý</span> break;
                        case SalesManagement.Data.Entities.OrderStatus.Done: <span class="badge bg-success">Hoàn thành</span> break;
                        default: <span class="badge bg-danger">Đã hủy</span> break;
                    }
                </dd>
            </dl>
        </div>
        <div class="col-md-6 text-end">
            <h4>Tổng tiền: @String.Format("{0:N0}", Model.Order.TotalAmount) ₫</h4>
        </div>
    </div>

    @if (Model.Order.Status == SalesManagement.Data.Entities.OrderStatus.Pending && User.IsInRole("Sales"))
    {
        <div class="d-flex gap-2 mb-4">
            <form method="post" asp-page-handler="Accept" asp-route-id="@Model.Order.Id"
                  onsubmit="return confirm('Xác nhận hoàn thành đơn hàng? Tồn kho sẽ bị trừ.');">
                <button class="btn btn-success">✅ Hoàn thành</button>
            </form>
            <form method="post" asp-page-handler="Cancel" asp-route-id="@Model.Order.Id"
                  onsubmit="return confirm('Bạn có chắc muốn hủy đơn hàng này?');">
                <button class="btn btn-danger">❌ Hủy đơn</button>
            </form>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-bordered">
            <thead class="table-light"><tr><th>Sản phẩm</th><th>Đơn giá</th><th>Số lượng</th><th>Thành tiền</th></tr></thead>
            <tbody>
                @foreach (var d in Model.Order.OrderDetails)
                {
                    <tr>
                        <td>@d.Product?.Name</td>
                        <td>@String.Format("{0:N0}", d.UnitPrice) ₫</td>
                        <td>@d.Quantity</td>
                        <td>@String.Format("{0:N0}", d.UnitPrice * d.Quantity) ₫</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
