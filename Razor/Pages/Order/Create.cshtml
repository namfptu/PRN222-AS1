@page
@namespace Razor.Pages.Orders
@model Razor.Pages.Orders.CreateModel
@{  ViewData["Title"] = "Tạo đơn hàng"; }
<div class="container-fluid pt-4 px-4">
    <div class="bg-light rounded p-4">
        <h6 class="mb-4">Tạo đơn hàng mới</h6>
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="Input.CustomerId" class="form-label">Khách hàng</label>
                    <select asp-for="Input.CustomerId" asp-items="Model.CustomerList" class="form-select">
                        <option value="">-- Chọn khách hàng --</option>
                    </select>
                    <span asp-validation-for="Input.CustomerId" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.Note" class="form-label"></label>
                    <input asp-for="Input.Note" class="form-control" placeholder="Ghi chú..." />
                </div>
            </div>

            <h6 class="mt-4 mb-3">Danh sách sản phẩm</h6>
            <div class="table-responsive">
                <table class="table table-bordered">
                    <thead class="table-light">
                        <tr><th>Mã SP</th><th>Tên sản phẩm</th><th>Đơn giá</th><th>Tồn kho</th><th>Số lượng đặt</th></tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Input.Items.Count; i++)
                        {
                            <tr>
                                <input type="hidden" asp-for="Input.Items[i].ProductId" />
                                <td><input type="hidden" asp-for="Input.Items[i].ProductCode" />@Model.Input.Items[i].ProductCode</td>
                                <td><input type="hidden" asp-for="Input.Items[i].ProductName" />@Model.Input.Items[i].ProductName</td>
                                <td><input type="hidden" asp-for="Input.Items[i].UnitPrice" />@String.Format("{0:N0}", Model.Input.Items[i].UnitPrice) ₫</td>
                                <td><input type="hidden" asp-for="Input.Items[i].AvailableQuantity" />@Model.Input.Items[i].AvailableQuantity</td>
                                <td style="width:120px">
                                    <input asp-for="Input.Items[i].Quantity" type="number" min="0" max="@Model.Input.Items[i].AvailableQuantity" class="form-control form-control-sm" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary">✅ Tạo đơn hàng</button>
                <a asp-page="/Order/Index" class="btn btn-secondary">Hủy</a>
            </div>
        </form>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
