@page
@namespace Razor.Pages.Orders
@model Razor.Pages.Orders.IndexModel
@{  ViewData["Title"] = "Quản lý Đơn hàng"; }
<div class="container-fluid pt-4 px-4">
    <div class="bg-light rounded p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h6 class="mb-0">Danh sách đơn hàng</h6>
            @if (User.IsInRole("Sales"))
            {
                <a asp-page="/Order/Create" class="btn btn-primary">+ Tạo đơn hàng</a>
            }
        </div>
        <div class="table-responsive">
            <table class="table table-hover">
                <thead><tr><th>Mã đơn</th><th>Ngày tạo</th><th>Khách hàng</th><th>SĐT</th><th>Tổng tiền</th><th>Trạng thái</th><th class="text-center">Chi tiết</th></tr></thead>
                <tbody>
                    @foreach (var o in Model.Orders)
                    {
                        <tr>
                            <td>@o.Code</td>
                            <td>@o.CreatedDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@o.CustomerName</td>
                            <td>@o.CustomerPhone</td>
                            <td>@String.Format("{0:N0}", o.TotalAmount) ₫</td>
                            <td>
                                @switch (o.Status)
                                {
                                    case SalesManagement.Data.Entities.OrderStatus.Pending: <span class="badge bg-warning">Chờ xử lý</span> break;
                                    case SalesManagement.Data.Entities.OrderStatus.Done: <span class="badge bg-success">Hoàn thành</span> break;
                                    default: <span class="badge bg-danger">Đã hủy</span> break;
                                }
                            </td>
                            <td class="text-center"><a asp-page="/Order/Details" asp-route-id="@o.Id" class="btn btn-sm btn-info">👁️</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
