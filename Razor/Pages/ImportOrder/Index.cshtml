@page
@namespace Razor.Pages.ImportOrders
@model Razor.Pages.ImportOrders.IndexModel
@{  ViewData["Title"] = "Quản lý Nhập kho"; }
<div class="container-fluid pt-4 px-4">
    <div class="bg-light rounded p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h6 class="mb-0">Danh sách phiếu nhập kho</h6>
            @if (User.IsInRole("Warehouse"))
            {
                <a asp-page="/ImportOrder/Create" class="btn btn-primary">+ Tạo phiếu nhập</a>
            }
        </div>
        <div class="table-responsive">
            <table class="table table-hover">
                <thead><tr><th>Mã phiếu</th><th>Ngày nhập</th><th>Nhà cung cấp</th><th>Tổng tiền</th><th>Ghi chú</th><th class="text-center">Chi tiết</th></tr></thead>
                <tbody>
                    @foreach (var io in Model.ImportOrders)
                    {
                        <tr>
                            <td>@io.Code</td>
                            <td>@io.ImportDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@io.Supplier?.CompanyName</td>
                            <td>@String.Format("{0:N0}", io.TotalCost) ₫</td>
                            <td>@io.Note</td>
                            <td class="text-center"><a asp-page="/ImportOrder/Details" asp-route-id="@io.Id" class="btn btn-sm btn-info">👁️</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
